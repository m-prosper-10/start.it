    "dsa",
    "express",
    "nestjs",
    "fastapi",
    "nextjs",
    "vite"
  ],
  "author": "Mugisha Pascal",
  "contributors": [
    "Mugisha Prosper"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
